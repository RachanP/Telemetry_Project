# ============================================================
#  SONiC Telemetry Stack — Central Configuration
#  แก้ไขที่นี่ที่เดียว แล้วทุกไฟล์จะใช้ค่านี้อัตโนมัติ
# ============================================================

# --- SONiC Switch ---
SWITCH_IP=192.168.1.11
SWITCH_PORT=8080
SWITCH_USER=admin
SWITCH_PASS=YourPaSsWoRd
SWITCH_NAME=switch1          # ชื่อ label ใน Prometheus / Grafana

# --- gNMI ---
GNMI_EXPORTER_PORT=9804
GNMI_SAMPLE_INTERVAL=20s     # ความถี่ในการดึงข้อมูล interface

# --- Temperature Exporter ---
TEMP_EXPORTER_PORT=9805
TEMP_SCRAPE_INTERVAL=30      # วินาที

# --- Prometheus ---
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=10s

# --- Grafana ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin