    { "type": "timeseries", "id": 10, "title": "Traffic Out (bytes/s)", "gridPos": { "x": 12, "y": 30, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "prometheus" }, "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }, "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }, "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(sonic__openconfig_interfaces_interfaces_interface_state_openconfig_interfaces_state_counters_out_octets[1m])", "legendFormat": "{{interface_name}}", "refId": "A" }] },
    { "type": "text", "id": 11, "gridPos": { "x": 0, "y": 38, "w": 24, "h": 2 }, "options": { "mode": "markdown", "content": "# ⚠️ Errors & Discards" } },
    { "type": "timeseries", "id": 12, "title": "In Errors & Discards (packets/s)", "gridPos": { "x": 0, "y": 40, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "prometheus" }, "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }, "fieldConfig": { "defaults": { "unit": "pps", "custom": { "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }, "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(sonic__openconfig_interfaces_interfaces_interface_state_openconfig_interfaces_state_counters_in_errors[1m]) > 0", "legendFormat": "in-errors {{interface_name}}", "refId": "A" }, { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(sonic__openconfig_interfaces_interfaces_interface_state_openconfig_interfaces_state_counters_in_discards[1m]) > 0", "legendFormat": "in-discards {{interface_name}}", "refId": "B" }] },
    { "type": "timeseries", "id": 13, "title": "Out Errors & Discards (packets/s)", "gridPos": { "x": 12, "y": 40, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "prometheus" }, "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }, "fieldConfig": { "defaults": { "unit": "pps", "custom": { "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }, "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(sonic__openconfig_interfaces_interfaces_interface_state_openconfig_interfaces_state_counters_out_errors[1m]) > 0", "legendFormat": "out-errors {{interface_name}}", "refId": "A" }, { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(sonic__openconfig_interfaces_interfaces_interface_state_openconfig_interfaces_state_counters_out_discards[1m]) > 0", "legendFormat": "out-discards {{interface_name}}", "refId": "B" }] },
    { "type": "table", "id": 14, "title": "Error Summary Table", "gridPos": { "x": 0, "y": 48, "w": 24, "h": 8 }, "datasource": { "type": "prometheus", "uid": "prometheus" }, "options": { "footer": { "show": false } }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "align": "left" } }, "overrides": [{ "matcher": { "id": "byRegexp", "options": ".*error.*|.*discard.*" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }] }] }, "transformations": [{ "id": "labelsToFields", "options": { "mode": "columns" } }, { "id": "organize", "options": { "excludeByName": { "Time": true, "job": true, "instance": true, "subscription_name": true, "subscription_target": true, "source": true, "target": true, "name": true }, "renameByName": { "interface_name": "Interface" } } }], "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sonic__openconfig_interfaces_interfaces_interface_state_openconfig_interfaces_state_counters_in_errors", "legendFormat": "in-errors", "refId": "A", "instant": true }, { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sonic__openconfig_interfaces_interfaces_interface_state_openconfig_interfaces_state_counters_in_discards", "legendFormat": "in-discards", "refId": "B", "instant": true }, { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sonic__openconfig_interfaces_interfaces_interface_state_openconfig_interfaces_state_counters_out_errors", "legendFormat": "out-errors", "refId": "C", "instant": true }, { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sonic__openconfig_interfaces_interfaces_interface_state_openconfig_interfaces_state_counters_out_discards", "legendFormat": "out-discards", "refId": "D", "instant": true }] }
  ]
