    { "type": "stat", "id": 6, "title": "Ports DOWN", "gridPos": { "x": 4, "y": 20, "w": 4, "h": 4 }, "datasource": { "type": "prometheus", "uid": "prometheus" }, "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" }, "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] } }, "overrides": [] }, "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(sonic__openconfig_interfaces_interfaces_interface_state_openconfig_interfaces_state_admin_status{admin_status=\"UP\",oper_status=\"DOWN\"})", "legendFormat": "DOWN", "refId": "A" }] },
    { "type": "table", "id": 7, "title": "Interface Status Table", "gridPos": { "x": 8, "y": 20, "w": 16, "h": 8 }, "datasource": { "type": "prometheus", "uid": "prometheus" }, "options": { "sortBy": [{ "displayName": "Interface", "desc": false }], "footer": { "show": false } }, "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [{ "matcher": { "id": "byName", "options": "oper_status" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [{ "type": "value", "options": { "UP": { "color": "green", "index": 0 }, "DOWN": { "color": "red", "index": 1 } } }] }] }] }, "transformations": [{ "id": "labelsToFields", "options": { "mode": "columns" } }, { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "job": true, "instance": true, "subscription_name": true, "subscription_target": true, "source": true, "target": true, "name": true }, "renameByName": { "interface_name": "Interface", "admin_status": "Admin", "oper_status": "Oper Status" } } }], "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sonic__openconfig_interfaces_interfaces_interface_state_openconfig_interfaces_state_admin_status", "legendFormat": "", "refId": "A", "instant": true }] },
